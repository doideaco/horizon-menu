{%- doc -%}
  Renders featured product cards from a collection in the mega menu.

  @param {object} collection - The collection to pull products from.
  @param {number} products_to_show - Number of products to display.
  @param {string} column_span - Number of grid columns to span (2, 3, or 4).
  @param {string} aspect_ratio - CSS aspect-ratio value for images.
  @param {boolean} show_price - Whether to show product price.
  @param {boolean} show_vendor - Whether to show product vendor.
  @param {string} view_all_label - Label for the view all link.
{%- enddoc -%}

{%- liquid
  assign col_span = column_span | default: 3 | plus: 0
  assign limit = products_to_show | default: 3
-%}

{% if collection != blank %}
  <li class="mega-menu__column mega-menu__column--span-{{ col_span }}">
    <div class="mega-menu__enhanced-grid">
      {% paginate collection.products by limit %}
        {% for product in collection.products %}
          <div class="mega-menu__enhanced-grid-item">
            {% render 'resource-card',
              resource: product,
              resource_type: 'product',
              image_hover: true,
              image_aspect_ratio: aspect_ratio,
              image_sizes: '(min-width: 990px) 200px, 150px',
              show_price: show_price,
              show_vendor: show_vendor
            %}
          </div>
        {% endfor %}
      {% endpaginate %}
    </div>
    {% if view_all_label != blank and collection.url != blank %}
      <a href="{{ collection.url }}" class="mega-menu__link mega-menu__view-all" style="margin-top: var(--padding-sm);">
        <span class="wrap-text">{{ view_all_label }}</span>
        <span class="mega-menu__view-all-arrow" aria-hidden="true">→</span>
      </a>
    {% endif %}
  </li>
{% endif %}

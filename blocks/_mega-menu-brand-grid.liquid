{%- doc -%}
  Mega menu brand logo grid block.
  Renders a grid of brand logos with links. Ideal for showcasing brands stocked by the store.
  Rendered by the parent _header-menu block via snippet, not directly.
{%- enddoc -%}

{% schema %}
{
  "name": "Mega menu: Brands",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "menu_item_title",
      "label": "Menu item title",
      "info": "Enter the exact title of the top-level menu item this block belongs to (e.g. 'Men', 'Women'). Case-insensitive."
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",

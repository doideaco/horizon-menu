{% doc %}
  @prompt
    Create a new slideshow section that works exactly like the existing "Slideshow: Full frame" section in this theme, but with the following addition: each slide's image should be a clickable link (with a URL field per slide). The text content (headings, subheadings, buttons) and layout should remain the same as the original full frame slideshow, but the entire image area should also be clickable/inkable. Content (headings and buttons) should be positioned at the bottom left of the image.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-slideshow-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-slideshow-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.slideshow_height_desktop }}vh;
  }

  @media screen and (max-width: 749px) {
    .ai-slideshow-container-{{ ai_gen_id }} {
      height: {{ block.settings.slideshow_height_mobile }}vh;
    }
  }

  .ai-slideshow-slides-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .ai-slideshow-slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.6s ease-in-out, visibility 0.6s ease-in-out;
  }

  .ai-slideshow-slide-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
    z-index: 1;
  }

  .ai-slideshow-slide-link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
    text-decoration: none;
    color: inherit;
  }

  .ai-slideshow-slide-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-slideshow-slide-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-slideshow-slide-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-slideshow-content-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    padding: {{ block.settings.content_padding_desktop }}px;
    z-index: 2;
    max-width: {{ block.settings.content_max_width }}px;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-slideshow-content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding_mobile }}px;
    }
  }

  .ai-slideshow-content-{{ ai_gen_id }} > * {
    pointer-events: auto;
  }

  .ai-slideshow-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 12px 0;
    font-weight: 500;
  }

  @media screen and (max-width: 749px) {
    .ai-slideshow-subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.8);
    }
  }

  .ai-slideshow-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 20px 0;
    line-height: 1.2;
  }

  @media screen and (max-width: 749px) {
    .ai-slideshow-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.6);
      margin: 0 0 16px 0;
    }
  }

  .ai-slideshow-buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .ai-slideshow-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.3s ease;
    text-transform: uppercase;
  }

  .ai-slideshow-button-primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.primary_button_bg }};
    color: {{ block.settings.primary_button_text }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.primary_button_border }};
  }

  .ai-slideshow-button-primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_button_hover_bg }};
    color: {{ block.settings.primary_button_hover_text }};
    border-color: {{ block.settings.primary_button_hover_border }};
  }

  .ai-slideshow-button-secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.secondary_button_bg }};
    color: {{ block.settings.secondary_button_text }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.secondary_button_border }};
  }

  .ai-slideshow-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_button_hover_bg }};
    color: {{ block.settings.secondary_button_hover_text }};
    border-color: {{ block.settings.secondary_button_hover_border }};
  }

  .ai-slideshow-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    background-color: {{ block.settings.nav_button_bg }};
    color: {{ block.settings.nav_button_color }};
    border: none;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    opacity: 0.8;
  }

  .ai-slideshow-nav-{{ ai_gen_id }}:hover {
    opacity: 1;
    background-color: {{ block.settings.nav_button_hover_bg }};
  }

  .ai-slideshow-nav-prev-{{ ai_gen_id }} {
    left: 20px;
  }

  .ai-slideshow-nav-next-{{ ai_gen_id }} {
    right: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-slideshow-nav-{{ ai_gen_id }} {
      width: 40px;
      height: 40px;
    }

    .ai-slideshow-nav-prev-{{ ai_gen_id }} {
      left: 12px;
    }

    .ai-slideshow-nav-next-{{ ai_gen_id }} {
      right: 12px;
    }
  }

  .ai-slideshow-nav-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  .ai-slideshow-dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    right: 20px;
    display: flex;
    gap: 8px;
    z-index: 3;
  }

  @media screen and (max-width: 749px) {
    .ai-slideshow-dots-{{ ai_gen_id }} {
      bottom: 12px;
      right: 12px;
    }
  }

  .ai-slideshow-dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.5;
    cursor: pointer;
    border: none;
    padding: 0;
    transition: opacity 0.3s ease;
  }

  .ai-slideshow-dot-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-slideshow-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }
{% endstyle %}

<slideshow-{{ ai_gen_id }} class="ai-slideshow-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-slideshow-container-{{ ai_gen_id }}">
    <div class="ai-slideshow-slides-{{ ai_gen_id }}">
      {% liquid
        assign slide_1_enabled = block.settings.slide_1_enabled
        assign slide_2_enabled = block.settings.slide_2_enabled
        assign slide_3_enabled = block.settings.slide_3_enabled
        assign slide_4_enabled = block.settings.slide_4_enabled
        assign slide_5_enabled = block.settings.slide_5_enabled

        assign has_slides = false
        if slide_1_enabled or slide_2_enabled or slide_3_enabled or slide_4_enabled or slide_5_enabled
          assign has_slides = true
        endif
      %}

      {% for i in (1..5) %}
        {% liquid
          assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
          assign slide_image_key = 'slide_' | append: i | append: '_image'
          assign slide_link_key = 'slide_' | append: i | append: '_link'
          assign slide_subheading_key = 'slide_' | append: i | append: '_subheading'
          assign slide_heading_key = 'slide_' | append: i | append: '_heading'
          assign slide_button_1_text_key = 'slide_' | append: i | append: '_button_1_text'
          assign slide_button_1_link_key = 'slide_' | append: i | append: '_button_1_link'
          assign slide_button_2_text_key = 'slide_' | append: i | append: '_button_2_text'
          assign slide_button_2_link_key = 'slide_' | append: i | append: '_button_2_link'

          assign slide_enabled = block.settings[slide_enabled_key]
          assign slide_image = block.settings[slide_image_key]
          assign slide_link = block.settings[slide_link_key]
          assign slide_subheading = block.settings[slide_subheading_key]
          assign slide_heading = block.settings[slide_heading_key]
          assign slide_button_1_text = block.settings[slide_button_1_text_key]
          assign slide_button_1_link = block.settings[slide_button_1_link_key]
          assign slide_button_2_text = block.settings[slide_button_2_text_key]
          assign slide_button_2_link = block.settings[slide_button_2_link_key]
        %}

        {% if slide_enabled %}
          <div class="ai-slideshow-slide-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-slide-index="{{ forloop.index }}">
            {% if slide_link != blank %}
              <a href="{{ slide_link }}" class="ai-slideshow-slide-link-{{ ai_gen_id }}">
            {% else %}
              <div class="ai-slideshow-slide-link-{{ ai_gen_id }}">
            {% endif %}
              {% if slide_image %}
                <img
                  src="{{ slide_image | image_url: width: 2000 }}"
                  alt="{{ slide_image.alt | escape }}"
                  loading="lazy"
                  width="{{ slide_image.width }}"
                  height="{{ slide_image.height }}"
                  class="ai-slideshow-slide-image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-slideshow-slide-placeholder-{{ ai_gen_id }}">
                  {{ 'hero-apparel-1' | placeholder_svg_tag }}
                </div>
              {% endif %}

              <div class="ai-slideshow-content-{{ ai_gen_id }}">
                {% if slide_subheading != blank %}
                  <div class="ai-slideshow-subheading-{{ ai_gen_id }}">{{ slide_subheading }}</div>
                {% endif %}

                {% if slide_heading != blank %}
                  <h2 class="ai-slideshow-heading-{{ ai_gen_id }}">{{ slide_heading }}</h2>
                {% endif %}

                {% if slide_button_1_text != blank or slide_button_2_text != blank %}
                  <div class="ai-slideshow-buttons-{{ ai_gen_id }}">
                    {% if slide_button_1_text != blank %}
                      <a
                        href="{{ slide_button_1_link | default: '#' }}"
                        class="ai-slideshow-button-{{ ai_gen_id }} ai-slideshow-button-primary-{{ ai_gen_id }}"
                      >
                        {{ slide_button_1_text }}
                      </a>
                    {% endif %}

                    {% if slide_button_2_text != blank %}
                      <a
                        href="{{ slide_button_2_link | default: '#' }}"
                        class="ai-slideshow-button-{{ ai_gen_id }} ai-slideshow-button-secondary-{{ ai_gen_id }}"
                      >
                        {{ slide_button_2_text }}
                      </a>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            {% if slide_link != blank %}
              </a>
            {% else %}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}

      {% unless has_slides %}
        <div class="ai-slideshow-slide-{{ ai_gen_id }} active">
          <div class="ai-slideshow-slide-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
            <div class="ai-slideshow-empty-state-{{ ai_gen_id }}">
              Next, enable and configure your slides
            </div>
          </div>
        </div>
      {% endunless %}
    </div>

    {% if block.settings.show_navigation and has_slides %}
      <button
        class="ai-slideshow-nav-{{ ai_gen_id }} ai-slideshow-nav-prev-{{ ai_gen_id }}"
        aria-label="Previous slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <button
        class="ai-slideshow-nav-{{ ai_gen_id }} ai-slideshow-nav-next-{{ ai_gen_id }}"
        aria-label="Next slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% endif %}

    {% if block.settings.show_dots and has_slides %}
      <div class="ai-slideshow-dots-{{ ai_gen_id }}"></div>
    {% endif %}
  </div>
</slideshow-{{ ai_gen_id }}>

<script>
  (function() {
    class Slideshow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slides = [];
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slides = Array.from(this.querySelectorAll('.ai-slideshow-slide-{{ ai_gen_id }}'));
        
        if (this.slides.length <= 1) {
          return;
        }

        this.setupNavigation();
        this.setupDots();
        this.setupAutoplay();
      }

      setupNavigation() {
        const prevButton = this.querySelector('.ai-slideshow-nav-prev-{{ ai_gen_id }}');
        const nextButton = this.querySelector('.ai-slideshow-nav-next-{{ ai_gen_id }}');

        if (prevButton) {
          prevButton.addEventListener('click', () => this.previousSlide());
        }

        if (nextButton) {
          nextButton.addEventListener('click', () => this.nextSlide());
        }
      }

      setupDots() {
        const dotsContainer = this.querySelector('.ai-slideshow-dots-{{ ai_gen_id }}');
        
        if (!dotsContainer) {
          return;
        }

        this.slides.forEach((slide, index) => {
          const dot = document.createElement('button');
          dot.classList.add('ai-slideshow-dot-{{ ai_gen_id }}');
          if (index === 0) {
            dot.classList.add('active');
          }
          dot.setAttribute('aria-label', `Go to slide ${index + 1}`);
          dot.addEventListener('click', () => this.goToSlide(index));
          dotsContainer.appendChild(dot);
        });

        this.dots = Array.from(dotsContainer.querySelectorAll('.ai-slideshow-dot-{{ ai_gen_id }}'));
      }

      setupAutoplay() {
        const autoplayEnabled = {{ block.settings.autoplay }};
        const autoplaySpeed = {{ block.settings.autoplay_speed }} * 1000;

        if (!autoplayEnabled) {
          return;
        }

        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, autoplaySpeed);

        this.addEventListener('mouseenter', () => {
          if (this.autoplayInterval) {
            clearInterval(this.autoplayInterval);
          }
        });

        this.addEventListener('mouseleave', () => {
          if (autoplayEnabled) {
            this.autoplayInterval = setInterval(() => {
              this.nextSlide();
            }, autoplaySpeed);
          }
        });
      }

      goToSlide(index) {
        this.slides[this.currentSlide].classList.remove('active');
        
        if (this.dots && this.dots[this.currentSlide]) {
          this.dots[this.currentSlide].classList.remove('active');
        }

        this.currentSlide = index;

        this.slides[this.currentSlide].classList.add('active');
        
        if (this.dots && this.dots[this.currentSlide]) {
          this.dots[this.currentSlide].classList.add('active');
        }
      }

      nextSlide() {
        const nextIndex = (this.currentSlide + 1) % this.slides.length;
        this.goToSlide(nextIndex);
      }

      previousSlide() {
        const prevIndex = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.goToSlide(prevIndex);
      }

      disconnectedCallback() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }
      }
    }

    customElements.define('slideshow-{{ ai_gen_id }}', Slideshow{{ ai_gen_id }});
  })();
</script>


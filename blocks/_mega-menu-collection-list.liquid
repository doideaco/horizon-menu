{%- doc -%}
  Mega menu collection list block.
  Rendered by the parent _header-menu block via snippet, not directly.
{%- enddoc -%}

{% schema %}
{
  "name": "Mega menu: Collections",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "menu_item_title",
      "label": "Menu item title",
      "info": "Enter the exact title of the top-level menu item this block belongs to (e.g. 'Men', 'Women'). Case-insensitive."
    },
    {
      "type": "header",
      "content": "Collections"
    },
    {
      "type": "collection",
      "id": "collection_1",
      "label": "Collection 1"
    },
    {
      "type": "collection",
      "id": "collection_2",
      "label": "Collection 2"
    },
    {
      "type": "collection",
      "id": "collection_3",
      "label": "Collection 3"
    },
    {
      "type": "collection",
      "id": "collection_4",
      "label": "Collection 4"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Image ratio",
      "options": [
        {
          "value": "adapt",
          "label": "Auto"
        },
        {
          "value": "16 / 9",
          "label": "Landscape (16:9)"
        },
        {
          "value": "1 / 1",
          "label": "Square (1:1)"
        }
      ],
      "default": "16 / 9"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show collection title",
      "default": true
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "column_span",
      "label": "Column width",
      "info": "The mega menu grid has 6 columns on desktop.",
      "options": [
        {
          "value": "2",
          "label": "2 columns"
        },
        {
          "value": "3",
          "label": "3 columns"
        },
        {
          "value": "4",
          "label": "4 columns"
        }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "position",
      "label": "Position",
      "options": [
        {
          "value": "start",
          "label": "Before links"
        },
        {
          "value": "end",
          "label": "After links"
        }
      ],
      "default": "end"
    }
  ]
}
{% endschema %}

{%- doc -%}
  Mega menu promotional image block.
  Rendered by the parent _header-menu block via snippet, not directly.
{%- enddoc -%}

{% schema %}
{
  "name": "Mega menu: Promo image",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "menu_item_title",
      "label": "Menu item title",
      "info": "Enter the exact title of the top-level menu item this block belongs to (e.g. 'Men', 'Women'). Case-insensitive."
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Image ratio",
      "options": [
        {
          "value": "16 / 9",
          "label": "Landscape (16:9)"
        },
        {
          "value": "4 / 5",
          "label": "Portrait (4:5)"
        },
        {
          "value": "1 / 1",
          "label": "Square (1:1)"
        }
      ],
      "default": "16 / 9"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text",
      "default": "Shop now"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "column_span",
      "label": "Column width",
      "info": "The mega menu grid has 6 columns on desktop.",
      "options": [
        {
          "value": "1",
          "label": "1 column"
        },
        {
          "value": "2",
          "label": "2 columns"
        },
        {
          "value": "3",
          "label": "3 columns"
        }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "position",
      "label": "Position",
      "options": [
        {
          "value": "start",
          "label": "Before links"
        },
        {
          "value": "end",
          "label": "After links"
        }
      ],
      "default": "end"
    }
  ]
}
{% endschema %}

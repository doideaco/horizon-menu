            "custom_liquid_RBLNpQ": {
              "type": "custom-liquid",
              "name": "Also available",
              "settings": {
                "custom_liquid": "{% capture activebrand %}{{ product.vendor | handleize }}{% endcapture %}\n{% capture currentproduct %}{{ product.title }}{% endcapture %}\n{% capture currenthandle %}{{ product.handle }}{% endcapture %}\n\n{% assign matching_products = '' %}\n\n{% if collections[activebrand].products.size > 1 %}\n  {% paginate collections[activebrand].products by 250 %}\n    {% for product in collections[activebrand].products %}\n      {% if product.title == currentproduct and product.handle != currenthandle %}\n        {% assign matching_products = matching_products | append: product.handle | append: ',' %}\n      {% endif %}\n    {% endfor %}\n  {% endpaginate %}\n{% endif %}\n\n{% assign matching_count = matching_products | split: ',' | size | minus: 1 %}\n\n{% if matching_count > 0 %}\n<div class=\"also-available-outer\">\n\n  <div class=\"also-available\">\n    {% paginate collections[activebrand].products by 250 %}\n      {% for product in collections[activebrand].products %}\n        {% if product.title == currentproduct and product.handle != currenthandle %}\n          <div>\n            <a href=\"{{ product.url }}\"> \n              <img src=\"{{ product.featured_image | product_img_url: '300x', format: 'pjpg' }}\"\n                   class=\"lazy\"\n                   data-src=\"{{ product.featured_image | product_img_url: '300x', format: 'pjpg' }}\"\n                   alt=\"{{ product.title }}\"\n                   title=\"{{ product.title }} - {{ product.variants[2].option3 }}\"\n                   height=\"200\"\n                   width=\"200\">\n            </a>\n          </div>\n        {% endif %}\n      {% endfor %}\n    {% endpaginate %}\n  </div>\n\n  <h3>Also available in</h3>\n\n</div>\n{% endif %}\n\n<style>\n\n  .also-available-outer {\n    display:flex;\n    flex-direction: column-reverse;\n    margin:10px 0;\n    padding:0;\n  }\n\n\n\n  .also-available-outer h3, .rebuy-widget .primary-title, #rebuy-widget-136162 .primary-title, .rebuy-widget .primary-title:first-letter, .related-products__heading {\n    letter-spacing: -0.03rem;\n    line-height: 1.1 !important    font-size:12px;\n    color: #222 !important;\n    font-size: 0.9rem;\n    margin:0 0 10px 0;\n  }\n  \n  .also-available {\n    width:100%;\n    max-width:50rem;\n    display:grid;\n    grid-template-columns:repeat(4,1fr);\n    gap:5px;\n  }\n  .also-available img {\n    width:100%;\n    height:auto;\n  }\n  .also-available-outer h3:empty { display:none }\n  \n</style>"
              },
